<div class="max-w-7xl mx-auto">
  <!-- Header -->
  <div class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Datasets</h1>
      <p class="mt-2 text-sm text-gray-600">Manage your data output tables and schemas</p>
    </div>
    <% if policy(Dataset).create? %>
      <%= link_to new_dataset_path, 
          class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-[#007cff] hover:bg-[#00d2ff] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#007cff] transition-colors" do %>
        <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        New Dataset
      <% end %>
    <% end %>
  </div>

  <!-- Datasets List -->
  <% if @datasets.any? %>
    <div class="bg-white shadow-sm rounded-lg overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Connector</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Table</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @datasets.each do |dataset| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4">
                <div class="max-w-sm" title="<%= dataset.description.present? ? dataset.description : dataset.name %>">
                  <%= link_to dataset.name, dataset_path(dataset), class: "text-sm font-medium text-[#007cff] hover:text-[#00d2ff] transition-colors truncate block" %>
                  <% if dataset.description.present? %>
                    <p class="text-sm text-gray-500 truncate"><%= dataset.description %></p>
                  <% end %>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <%= link_to dataset.connector.name, connector_path(dataset.connector), class: "text-[#007cff] hover:text-[#00d2ff] transition-colors" %>
              </td>
              <td class="px-6 py-4">
                <code class="text-sm font-mono bg-gray-100 px-2 py-1 rounded truncate block max-w-sm" title="<%= dataset.table_name %>"><%= dataset.table_name %></code>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% status_color = case dataset.status
                                  when "draft" then "yellow"
                                  when "active" then "green"
                                  when "archived" then "gray"
                                  end %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-<%= status_color %>-100 text-<%= status_color %>-800">
                  <%= dataset.status.titleize %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      </div>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="bg-white shadow-sm rounded-lg p-12 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900">No datasets</h3>
      <p class="mt-1 text-sm text-gray-500">Get started by creating a new dataset.</p>
      <% if policy(Dataset).create? %>
        <div class="mt-6">
          <%= link_to new_dataset_path, 
              class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-[#007cff] hover:bg-[#00d2ff] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#007cff] transition-colors" do %>
            <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            New Dataset
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
