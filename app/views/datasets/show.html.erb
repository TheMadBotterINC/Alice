<div class="max-w-7xl mx-auto">
  <!-- Header -->
  <div class="mb-6">
    <div class="flex items-center justify-between">
      <div>
        <div class="flex items-center space-x-3">
          <h1 class="text-3xl font-bold text-gray-900"><%= @dataset.name %></h1>
          <% status_color = case @dataset.status
                            when "draft" then "yellow"
                            when "active" then "green"
                            when "archived" then "gray"
                            end %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-<%= status_color %>-100 text-<%= status_color %>-800">
            <%= @dataset.status.titleize %>
          </span>
        </div>
        <% if @dataset.description.present? %>
          <p class="mt-2 text-sm text-gray-600"><%= @dataset.description %></p>
        <% end %>
      </div>
      <div class="flex items-center space-x-3 flex-shrink-0">
        <% if policy(Dataset).create? || current_user.viewer? %>
          <%= link_to new_pipeline_path(source_dataset_id: @dataset.id), 
              class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-colors",
              title: "Create a new pipeline using this dataset" do %>
            <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            Create Pipeline
          <% end %>
        <% end %>
        <%= link_to data_dataset_path(@dataset), 
            class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-[#007cff] hover:bg-[#00d2ff] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#007cff] transition-colors" do %>
          <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
          View Data
        <% end %>
        <% if policy(Dataset).create? %>
          <%= link_to edit_dataset_path(@dataset), 
              class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#007cff] transition-colors" do %>
            <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
            Edit
          <% end %>
        <% end %>
        <% if policy(@dataset).destroy? %>
          <%= button_to @dataset, method: :delete, 
              data: { turbo_confirm: "Are you sure you want to delete this dataset? This action cannot be undone." }, 
              class: "inline-flex items-center px-4 py-2 border border-red-300 rounded-md shadow-sm text-sm font-medium text-red-700 bg-white hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition-colors" do %>
            <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
            </svg>
            Delete
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-6">
    <!-- Dataset Details -->
    <div class="space-y-6">
      <!-- Configuration Card -->
      <div class="bg-white shadow-sm rounded-lg overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200">
          <h2 class="text-lg font-medium text-gray-900">Configuration</h2>
        </div>
        <div class="px-6 py-4 space-y-4">
          <div>
            <dt class="text-sm font-medium text-gray-500">Connector</dt>
            <dd class="mt-1 text-sm text-gray-900">
              <%= link_to @dataset.connector.name, connector_path(@dataset.connector), class: "text-[#007cff] hover:text-[#00d2ff] font-medium transition-colors" %>
              <span class="text-gray-500">(<%= @dataset.connector.connector_type.titleize %>)</span>
            </dd>
          </div>

          <div>
            <dt class="text-sm font-medium text-gray-500">Table Name</dt>
            <dd class="mt-1">
              <code class="text-sm font-mono bg-gray-100 px-2 py-1 rounded"><%= @dataset.table_name %></code>
            </dd>
          </div>

          <div>
            <dt class="text-sm font-medium text-gray-500">Fully Qualified Name</dt>
            <dd class="mt-1">
              <code class="text-sm font-mono bg-gray-100 px-2 py-1 rounded"><%= @dataset.fully_qualified_name %></code>
            </dd>
          </div>

          <div>
            <dt class="text-sm font-medium text-gray-500">Row Count</dt>
            <dd class="mt-1 text-sm text-gray-900">
              <%= number_with_delimiter(@dataset.row_count || 0) %> rows
            </dd>
          </div>

          <% if @dataset.last_updated_at.present? %>
            <div>
              <dt class="text-sm font-medium text-gray-500">Last Updated</dt>
              <dd class="mt-1 text-sm text-gray-900">
                <%= time_ago_in_words(@dataset.last_updated_at) %> ago
              </dd>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Schema Card -->
      <div class="bg-white shadow-sm rounded-lg overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200">
          <h2 class="text-lg font-medium text-gray-900">Schema</h2>
        </div>
        <% if @dataset.schema.present? && @dataset.schema['columns'].present? && @dataset.column_names.any? %>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Column Name</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Data Type</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                <% @dataset.schema['columns'].each do |column| %>
                  <tr>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-mono text-gray-900"><%= column['name'] %></td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= column['type'] %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="px-6 py-8 text-center text-gray-500">
            <svg class="mx-auto h-8 w-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <p class="mt-2 text-sm">No schema defined</p>
          </div>
        <% end %>
      </div>
      
      <!-- Related Pipelines Card -->
      <% downstream_pipelines = @dataset.downstream_pipelines.includes(:destination_dataset, :destination_connector) %>
      <% upstream_pipelines = @dataset.upstream_pipelines.includes(:destination_dataset, :destination_connector) %>
      <% if downstream_pipelines.any? || upstream_pipelines.any? %>
        <div class="bg-white shadow-sm rounded-lg overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-lg font-medium text-gray-900">Related Pipelines</h2>
            <p class="mt-1 text-sm text-gray-500">Pipelines that read from or write to this dataset</p>
          </div>
          <div class="px-6 py-4 space-y-6">
            <!-- Pipelines Writing TO This Dataset -->
            <% if downstream_pipelines.any? %>
              <div>
                <h3 class="text-sm font-semibold text-gray-700 mb-3 flex items-center">
                  <svg class="w-4 h-4 mr-2 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                  Upstream Pipelines (Write TO this dataset)
                </h3>
                <div class="space-y-2">
                  <% downstream_pipelines.each do |pipeline| %>
                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                      <div class="flex items-center space-x-3 min-w-0 flex-1">
                        <div class="flex-shrink-0">
                          <svg class="h-8 w-8 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                          </svg>
                        </div>
                        <div class="min-w-0 flex-1">
                          <%= link_to pipeline.name, pipeline_path(pipeline), class: "text-sm font-medium text-gray-900 hover:text-[#007cff] truncate block" %>
                          <% if pipeline.description.present? %>
                            <p class="text-xs text-gray-500 truncate"><%= pipeline.description %></p>
                          <% end %>
                        </div>
                      </div>
                      <div class="flex-shrink-0">
                        <% status_color = case pipeline.status
                                          when "succeeded" then "green"
                                          when "failed" then "red"
                                          when "running" then "yellow"
                                          else "gray"
                                          end %>
                        <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-<%= status_color %>-100 text-<%= status_color %>-800">
                          <%= pipeline.status.titleize %>
                        </span>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
            
            <!-- Pipelines Reading FROM This Dataset -->
            <% if upstream_pipelines.any? %>
              <div>
                <h3 class="text-sm font-semibold text-gray-700 mb-3 flex items-center">
                  <svg class="w-4 h-4 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
                  </svg>
                  Downstream Pipelines (Read FROM this dataset)
                </h3>
                <div class="space-y-2">
                  <% upstream_pipelines.each do |pipeline| %>
                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                      <div class="flex items-center space-x-3 min-w-0 flex-1">
                        <div class="flex-shrink-0">
                          <svg class="h-8 w-8 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                          </svg>
                        </div>
                        <div class="min-w-0 flex-1">
                          <%= link_to pipeline.name, pipeline_path(pipeline), class: "text-sm font-medium text-gray-900 hover:text-[#007cff] truncate block" %>
                          <% if pipeline.description.present? %>
                            <p class="text-xs text-gray-500 truncate"><%= pipeline.description %></p>
                          <% end %>
                        </div>
                      </div>
                      <div class="flex-shrink-0">
                        <% status_color = case pipeline.status
                                          when "succeeded" then "green"
                                          when "failed" then "red"
                                          when "running" then "yellow"
                                          else "gray"
                                          end %>
                        <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-<%= status_color %>-100 text-<%= status_color %>-800">
                          <%= pipeline.status.titleize %>
                        </span>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
      
      <!-- Sample Data Preview -->
      <div class="bg-white shadow-sm rounded-lg overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
          <div>
            <h2 class="text-lg font-medium text-gray-900">Data Preview</h2>
            <p class="mt-1 text-sm text-gray-500">Showing first 10 rows</p>
          </div>
          <%= link_to data_dataset_path(@dataset), 
              class: "inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-white bg-[#007cff] hover:bg-[#00d2ff] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#007cff]" do %>
            <svg class="-ml-0.5 mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
            View Full Data
          <% end %>
        </div>
        <% if @sample_data.present? %>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <% column_names = @dataset.column_names.presence || @sample_data.first&.keys || [] %>
                  <% column_names.each do |col_name| %>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                      <%= col_name %>
                    </th>
                  <% end %>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                <% @sample_data.first(10).each do |row| %>
                  <tr class="hover:bg-gray-50">
                    <% column_names.each do |col_name| %>
                      <td class="px-6 py-4 text-sm text-gray-900">
                        <% value = row[col_name] || row[col_name.downcase] || row[col_name.upcase] %>
                        <% if value.nil? %>
                          <span class="text-gray-400 italic">NULL</span>
                        <% elsif value.to_s.length > 50 %>
                          <span class="block truncate max-w-xs" title="<%= value %>">
                            <%= value.to_s.truncate(50) %>
                          </span>
                        <% else %>
                          <%= value %>
                        <% end %>
                      </td>
                    <% end %>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="px-6 py-8 text-center">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
            </svg>
            <h3 class="mt-2 text-sm font-medium text-gray-900">No data available</h3>
            <p class="mt-1 text-sm text-gray-500">
              Could not load sample data. The table may be empty or there may be a connection issue.
            </p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
