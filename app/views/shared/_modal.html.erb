<%# 
  Modal Component
  
  Usage:
    <%= render "shared/modal", id: "my-modal", title: "Confirm Action" do %>
      <p>Are you sure you want to proceed?</p>
      
      <div class="mt-6 flex justify-end space-x-3">
        <%= alice_button "Cancel", variant: :secondary, data: { action: "click->modal#close" } %>
        <%= alice_button "Confirm", variant: :danger %>
      </div>
    <% end %>
    
  To open from a button:
    <%= alice_button "Open Modal", data: { action: "click->modal#open", modal_target: "my-modal" } %>
-%>

<% 
  modal_id = local_assigns[:id] || "modal-#{SecureRandom.hex(4)}"
  title = local_assigns[:title] || "Modal"
  size = local_assigns[:size] || :md # :sm, :md, :lg, :xl
  
  size_class = case size
  when :sm then "max-w-md"
  when :lg then "max-w-4xl"
  when :xl then "max-w-6xl"
  else "max-w-2xl"
  end
%>

<div id="<%= modal_id %>" 
     class="hidden fixed inset-0 z-50 overflow-y-auto" 
     data-controller="modal"
     aria-labelledby="<%= modal_id %>-title"
     aria-modal="true"
     role="dialog">
  
  <!-- Backdrop -->
  <div data-modal-target="backdrop"
       data-action="click->modal#closeOnBackdrop"
       class="fixed inset-0 bg-gray-600 bg-opacity-75 transition-opacity"></div>

  <!-- Modal Container -->
  <div class="flex min-h-full items-center justify-center p-4">
    <div data-modal-target="container"
         data-action="click->modal#preventClose"
         class="relative bg-white rounded-lg shadow-xl <%= size_class %> w-full">
      
      <!-- Header -->
      <div class="flex items-center justify-between p-6 border-b border-gray-200">
        <h3 id="<%= modal_id %>-title" class="text-xl font-semibold text-gray-900">
          <%= title %>
        </h3>
        <button type="button"
                data-action="click->modal#close"
                class="text-gray-400 hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-primary rounded-lg p-1"
                aria-label="Close modal">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <!-- Content -->
      <div class="p-6">
        <%= yield %>
      </div>
    </div>
  </div>
</div>
