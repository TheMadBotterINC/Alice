<aside data-controller="sidebar">
  <!-- Mobile Backdrop -->
  <div data-sidebar-target="backdrop" 
       data-action="click->sidebar#closeOnBackdrop"
       class="hidden fixed inset-0 bg-gray-600 bg-opacity-75 z-40 lg:hidden"
       aria-hidden="true"></div>

  <!-- Mobile Sidebar -->
  <div data-sidebar-target="menu"
       class="fixed inset-y-0 left-0 z-50 w-64 bg-white transform -translate-x-full transition-transform duration-300 ease-in-out lg:hidden">
    <div class="h-full flex flex-col">
      <!-- Mobile Sidebar Header -->
      <div class="flex items-center justify-between h-16 px-4 border-b border-gray-200">
        <h2 class="text-xl font-bold text-primary-dark">Menu</h2>
        <button type="button" 
                data-action="click->sidebar#close"
                class="p-2 rounded-md text-gray-700 hover:bg-gray-100"
                aria-label="Close sidebar">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <!-- Mobile Navigation -->
      <div class="flex-1 overflow-y-auto p-4">
        <%= render "shared/navigation" %>
      </div>
    </div>
  </div>

  <!-- Desktop Sidebar -->
  <div class="hidden lg:flex lg:flex-shrink-0">
    <div data-sidebar-target="desktop" class="w-64 flex flex-col transition-all duration-300 ease-in-out">
      <div class="flex-1 flex flex-col min-h-0 bg-white border-r border-gray-200">
        <div class="flex-1 flex flex-col pt-5 pb-4 overflow-y-auto">
          <!-- Collapse Toggle Button -->
          <div class="px-4 mb-2 flex justify-center">
            <button type="button" 
                    data-sidebar-target="toggleBtn"
                    data-action="click->sidebar#toggleCollapse"
                    class="p-2 rounded-lg text-gray-500 hover:bg-gray-100 hover:text-gray-700 transition-colors"
                    title="Toggle sidebar">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"></path>
              </svg>
            </button>
          </div>
          
          <div class="flex-1 px-4 space-y-1">
            <%= render "shared/navigation" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</aside>
