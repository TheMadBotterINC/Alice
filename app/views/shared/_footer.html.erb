<footer class="bg-white border-t border-gray-200 mt-auto" role="contentinfo">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="flex flex-col md:flex-row justify-between items-center">
      <!-- Left: Copyright -->
      <div class="text-sm text-gray-500">
        &copy; <%= Time.current.year %> Alice. All rights reserved.
      </div>

      <!-- Center: Version (only for admins) -->
      <% if current_user.admin? %>
        <div class="text-xs text-gray-400 mt-2 md:mt-0">
          Version 0.1.0 (MVP)
        </div>
      <% end %>

      <!-- Right: Support Links -->
      <div class="flex space-x-4 text-sm text-gray-500 mt-2 md:mt-0">
        <a href="#" class="hover:text-primary">Documentation</a>
        <a href="#" class="hover:text-primary">Support</a>
      </div>
    </div>
  </div>
</footer>
