<div class="space-y-6">
  <div>
    <div class="flex items-center">
      <%= link_to connector_path(@connector), class: "text-gray-400 hover:text-gray-600" do %>
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
      <% end %>
      <h1 class="ml-2 text-3xl font-bold text-gray-900">Edit Connector</h1>
    </div>
    <p class="mt-2 text-sm text-gray-600">Update connector configuration</p>
  </div>

  <%= render "form", connector: @connector %>
</div>
