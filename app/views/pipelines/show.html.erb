<% if @pipeline_runs.any? { |r| r.status.in?(["pending", "running"]) } %>
  <meta http-equiv="refresh" content="3">
<% end %>

<div class="max-w-7xl mx-auto">
  <!-- Success Banner for Latest Run -->
  <% latest_run = @pipeline.pipeline_runs.order(started_at: :desc).first %>
  <% if latest_run&.succeeded? && latest_run.created_at > 30.seconds.ago %>
    <div class="mb-6 bg-green-50 border-l-4 border-green-400 p-4 rounded-md">
      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div class="ml-3">
            <p class="text-sm font-medium text-green-800">
              Pipeline executed successfully! 
              <% if latest_run.output_file.attached? %>
                Your CSV file is ready.
              <% end %>
            </p>
          </div>
        </div>
        <% if latest_run.output_file.attached? %>
          <%= link_to rails_blob_path(latest_run.output_file, disposition: "attachment"), class: "inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" do %>
            <svg class="h-4 w-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
            </svg>
            Download CSV
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
  
  <!-- Header -->
  <div class="mb-6">
    <div class="flex items-start justify-between">
      <div>
        <div class="flex items-center space-x-3">
          <h1 class="text-3xl font-bold text-gray-900"><%= @pipeline.name %></h1>
          <% status_color = case @pipeline.status
                            when "idle" then "gray"
                            when "running" then "blue"
                            when "success" then "green"
                            when "failure" then "red"
                            end %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-<%= status_color %>-100 text-<%= status_color %>-800">
            <%= @pipeline.status.titleize %>
          </span>
        </div>
        <% if @pipeline.description.present? %>
          <p class="mt-2 text-sm text-gray-600"><%= @pipeline.description %></p>
        <% end %>
      </div>
      <div class="flex items-center space-x-3">
        <% if policy(@pipeline).update? %>
          <% if @pipeline.visual_mode? %>
            <%= link_to visual_builder_pipeline_path(@pipeline), class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-alice-secondary hover:from-blue-700 hover:to-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
              🎨 Visual Builder
            <% end %>
          <% end %>
          <% upload_connectors = @pipeline.source_connectors.select(&:upload_mode?) %>
          <% if upload_connectors.any? %>
            <!-- Show modal button for pipelines with upload connectors -->
            <button type="button"
                    data-action="click->modal#open"
                    data-modal-target="runPipelineModal"
                    class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 cursor-pointer">
              <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
              </svg>
              Run with Files
            </button>
          <% else %>
            <!-- Simple run button for pipelines without uploads -->
            <%= form_with url: run_pipeline_path(@pipeline), method: :post, class: "inline-block" do |f| %>
              <%= f.submit "Run Now", class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 cursor-pointer" %>
            <% end %>
          <% end %>
          <%= link_to "Edit", edit_pipeline_path(@pipeline), class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary" %>
        <% end %>
        <% if policy(@pipeline).destroy? %>
          <%= button_to "Delete", @pipeline, method: :delete, data: { turbo_confirm: "Are you sure you want to delete this pipeline? This will also delete all associated run history." }, class: "inline-flex items-center px-4 py-2 border border-red-300 rounded-md shadow-sm text-sm font-medium text-red-700 bg-white hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Pipeline Details -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Configuration Card -->
      <div class="bg-white shadow-sm rounded-lg overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200">
          <h2 class="text-lg font-medium text-gray-900">Configuration</h2>
        </div>
        <div class="px-6 py-4 space-y-4">
          <div>
            <dt class="text-sm font-medium text-gray-500">Data Sources</dt>
            <dd class="mt-1 text-sm text-gray-900">
              <% if @pipeline.pipeline_sources.any? %>
                <ul class="space-y-2">
                  <% @pipeline.pipeline_sources.includes(:connector, :dataset).each do |source| %>
                    <li class="flex items-center">
                      <% if source.connector %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800 mr-2">
                          Connector
                        </span>
                        <%= link_to source.connector.name, connector_path(source.connector), class: "text-primary hover:text-primary-dark font-medium" %>
                        <span class="text-gray-500 ml-1">(<%= source.connector.connector_type.titleize %>)</span>
                      <% elsif source.dataset %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800 mr-2">
                          Dataset
                        </span>
                        <%= link_to source.dataset.name, dataset_path(source.dataset), class: "text-primary hover:text-primary-dark font-medium" %>
                        <span class="text-xs text-gray-500 ml-1 block"><%= source.dataset.fully_qualified_name %></span>
                      <% end %>
                    </li>
                  <% end %>
                </ul>
              <% else %>
                <span class="text-gray-400 italic">No data sources configured</span>
              <% end %>
            </dd>
          </div>

          <div>
            <dt class="text-sm font-medium text-gray-500">Destination</dt>
            <dd class="mt-1 text-sm text-gray-900">
              <% if @pipeline.destination_dataset.present? %>
                <%= link_to @pipeline.destination_dataset.name, dataset_path(@pipeline.destination_dataset), class: "text-primary hover:text-primary-dark" %>
                <div class="text-xs text-gray-500 mt-1">
                  <span class="font-mono"><%= @pipeline.destination_dataset.source_table_path %></span>
                  <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">Dataset</span>
                </div>
              <% elsif @pipeline.destination_connector.present? %>
                <%= link_to @pipeline.destination_connector.name, connector_path(@pipeline.destination_connector), class: "text-primary hover:text-primary-dark" %>
                <span class="text-gray-500">(<%= @pipeline.destination_connector.connector_type.titleize %>)</span>
                <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-800">Connector (Legacy)</span>
              <% else %>
                <span class="text-gray-400 italic">No destination (transformation only)</span>
              <% end %>
            </dd>
          </div>

          <% if @pipeline.destination_dataset.present? || @pipeline.destination_connector.present? %>
            <div>
              <dt class="text-sm font-medium text-gray-500">Write Disposition</dt>
              <dd class="mt-1 text-sm text-gray-900">
                <span class="capitalize"><%= @pipeline.write_disposition.humanize %></span>
                <% if @pipeline.write_disposition == "merge" && @pipeline.merge_key.present? %>
                  <span class="ml-2 text-xs text-gray-500">
                    (Merge Key: <code class="font-mono bg-gray-100 px-1.5 py-0.5 rounded"><%= @pipeline.merge_key %></code>)
                  </span>
                <% end %>
              </dd>
            </div>
          <% end %>

          <div>
            <dt class="text-sm font-medium text-gray-500">Schedule</dt>
            <dd class="mt-1 text-sm text-gray-900">
              <% if @pipeline.schedule.present? %>
                <code class="font-mono bg-gray-100 px-2 py-1 rounded"><%= @pipeline.schedule %></code>
              <% else %>
                <span class="text-gray-400 italic">Manual runs only</span>
              <% end %>
            </dd>
          </div>

          <div>
            <dt class="text-sm font-medium text-gray-500">Last Run</dt>
            <dd class="mt-1 text-sm text-gray-900">
              <% if @pipeline.last_run_at.present? %>
                <%= time_ago_in_words(@pipeline.last_run_at) %> ago
              <% else %>
                <span class="text-gray-400 italic">Never run</span>
              <% end %>
            </dd>
          </div>

          <div>
            <dt class="text-sm font-medium text-gray-500">Success Rate</dt>
            <dd class="mt-1">
              <div class="flex items-center space-x-3">
                <div class="flex-1">
                  <div class="w-full bg-gray-200 rounded-full h-2">
                    <div class="bg-green-600 h-2 rounded-full" style="width: <%= @pipeline.success_rate %>%"></div>
                  </div>
                </div>
                <span class="text-sm font-medium text-gray-900"><%= number_to_percentage(@pipeline.success_rate, precision: 1) %></span>
              </div>
            </dd>
          </div>
        </div>
      </div>

      <!-- SQL Query Card -->
      <div class="bg-white shadow-sm rounded-lg overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200">
          <h2 class="text-lg font-medium text-gray-900">Transformation SQL</h2>
        </div>
        <div class="px-6 py-4">
          <pre class="text-sm font-mono bg-gray-50 p-4 rounded-lg overflow-x-auto"><%= @pipeline.transformation_sql %></pre>
        </div>
      </div>
    </div>

    <!-- Run History Sidebar -->
    <div class="lg:col-span-1">
      <div class="bg-white shadow-sm rounded-lg overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200">
          <h2 class="text-lg font-medium text-gray-900">Recent Runs</h2>
        </div>
        <div class="divide-y divide-gray-200">
          <% if @pipeline.pipeline_runs.any? %>
            <% @pipeline.pipeline_runs.order(started_at: :desc).limit(10).each do |run| %>
              <div class="px-6 py-4 hover:bg-gray-50">
                <div class="flex items-center justify-between">
                  <% run_status_color = case run.status
                                        when "pending" then "gray"
                                        when "running" then "blue"
                                        when "success" then "green"
                                        when "failure" then "red"
                                        end %>
                  <div>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-<%= run_status_color %>-100 text-<%= run_status_color %>-800">
                      <%= run.status.titleize %>
                    </span>
                    
                    <!-- Progress indicator for pending/running states -->
                    <% if run.status.in?(["pending", "running"]) %>
                      <div class="mt-2 w-32">
                        <div class="h-1 bg-gray-200 rounded-full overflow-hidden">
                          <div class="h-full bg-<%= run.status == 'pending' ? 'gray' : 'blue' %>-500 rounded-full animate-progress"></div>
                        </div>
                        <p class="text-xs text-gray-500 mt-1">
                          <% if run.status == "pending" %>
                            Queued...
                          <% else %>
                            Executing...
                          <% end %>
                        </p>
                      </div>
                    <% end %>
                  </div>
                  <span class="text-xs text-gray-500">
                    <%= time_ago_in_words(run.started_at) %> ago
                  </span>
                </div>
                <% if run.duration.present? %>
                  <p class="mt-1 text-xs text-gray-500">
                    Duration: <%= distance_of_time_in_words(run.duration) %>
                  </p>
                <% end %>
                <% if run.error_message.present? %>
                  <p class="mt-1 text-xs text-red-600 truncate" title="<%= run.error_message %>">
                    <%= run.error_message %>
                  </p>
                <% end %>
                <% if run.output_file.attached? %>
                  <%= link_to rails_blob_path(run.output_file, disposition: "attachment"), class: "mt-2 inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-md text-white bg-primary hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary max-w-full" do %>
                    <svg class="h-4 w-4 mr-1.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                    </svg>
                    <span class="truncate">Download <%= run.output_file.filename %></span>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          <% else %>
            <div class="px-6 py-8 text-center">
              <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
              </svg>
              <p class="mt-2 text-sm text-gray-500">No runs yet</p>
              <% if policy(@pipeline).update? %>
                <p class="mt-1 text-xs text-gray-400">Click "Run Now" to start</p>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- File Upload Modal -->
<% if @pipeline.source_connectors.any?(&:upload_mode?) %>
  <div id="runPipelineModal" class="hidden fixed inset-0 z-50 overflow-y-auto" data-controller="modal">
    <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
      <!-- Background overlay -->
      <div class="fixed inset-0 transition-opacity bg-gray-500 bg-opacity-75" data-action="click->modal#close"></div>

      <!-- Modal panel -->
      <div class="inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
        <%= form_with url: run_pipeline_path(@pipeline), method: :post, multipart: true do |f| %>
          <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
            <div class="sm:flex sm:items-start">
              <div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-green-100 sm:mx-0 sm:h-10 sm:w-10">
                <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
                </svg>
              </div>
              <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left w-full">
                <h3 class="text-lg leading-6 font-medium text-gray-900">Run Pipeline with Files</h3>
                <div class="mt-4 space-y-4">
                  <p class="text-sm text-gray-500">
                    This pipeline requires file uploads. Please select files for the following connectors:
                  </p>
                  
                  <% @pipeline.source_connectors.select(&:upload_mode?).each_with_index do |connector, index| %>
                    <div class="border border-gray-300 rounded-md p-4">
                      <label class="block text-sm font-medium text-gray-700 mb-2">
                        <%= connector.name %>
                        <% if connector.connector_type == 'file_upload' %>
                          <span class="text-xs text-gray-500">(Auto-detect CSV/TSV/Excel)</span>
                        <% else %>
                          <span class="text-xs text-gray-500">(<%= connector.connector_type.gsub('file_', '').upcase %>)</span>
                        <% end %>
                      </label>
                      <%= f.file_field "source_files[]", 
                          accept: case connector.connector_type
                                  when 'file_csv'
                                    '.csv,.tsv,.txt'
                                  when 'file_excel'
                                    '.xlsx,.xls'
                                  when 'file_upload'
                                    '.csv,.tsv,.txt,.xlsx,.xls'
                                  else
                                    ''
                                  end,
                          required: true,
                          class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-primary file:text-white hover:file:bg-primary-dark" %>
                      <p class="mt-1 text-xs text-gray-500">
                        <% if connector.connector_type == 'file_upload' %>
                          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">
                            🤖 Auto-detects format
                          </span>
                          <span class="ml-1">Supports CSV, TSV, Excel (.xlsx, .xls)</span>
                        <% else %>
                          <% if connector.config['has_header'] %>
                            ✔ Expects header row
                          <% end %>
                          <% if connector.connector_type == 'file_csv' %>
                            | Delimiter: <%= connector.config['delimiter'] || ',' %>
                          <% end %>
                        <% end %>
                      </p>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
          <div class="bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
            <%= f.submit "Run Pipeline", class: "w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-green-600 text-base font-medium text-white hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 sm:ml-3 sm:w-auto sm:text-sm cursor-pointer" %>
            <button type="button" 
                    data-action="click->modal#close"
                    class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
              Cancel
            </button>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

