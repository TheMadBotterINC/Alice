<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="sm:flex sm:items-center sm:justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Pipeline Templates</h1>
      <p class="mt-2 text-sm text-gray-700">
        Reusable pipeline configurations that you can use to quickly create new pipelines.
      </p>
    </div>
    <div class="mt-4 sm:mt-0">
      <%= link_to pipelines_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" do %>
        <svg class="mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Pipelines
      <% end %>
    </div>
  </div>

  <% if @templates.any? %>
    <div class="bg-white shadow-sm rounded-lg overflow-hidden">
      <ul role="list" class="divide-y divide-gray-200">
        <% @templates.each do |template| %>
          <li class="px-6 py-6 hover:bg-gray-50">
            <div class="flex items-center justify-between">
              <div class="flex-1 min-w-0">
                <div class="flex items-center space-x-3">
                  <svg class="h-8 w-8 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path>
                  </svg>
                  <div>
                    <h2 class="text-lg font-medium text-gray-900">
                      <%= template.name %>
                    </h2>
                    <% if template.description.present? %>
                      <p class="mt-1 text-sm text-gray-500 line-clamp-2">
                        <%= template.description.gsub(/\[Template created from:.*\]/, '').strip %>
                      </p>
                    <% end %>
                  </div>
                </div>

                <div class="mt-4 flex items-center space-x-4 text-sm text-gray-500">
                  <div class="flex items-center">
                    <svg class="mr-1.5 h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"></path>
                    </svg>
                    <%= pluralize(template.pipeline_sources.count, "source") %>
                  </div>

                  <% if template.destination_connector || template.destination_dataset %>
                    <div class="flex items-center">
                      <svg class="mr-1.5 h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                      </svg>
                      Destination configured
                    </div>
                  <% end %>

                  <div class="flex items-center">
                    <svg class="mr-1.5 h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    Created <%= time_ago_in_words(template.created_at) %> ago
                  </div>
                </div>
              </div>

              <div class="ml-6 flex-shrink-0">
                <button onclick="showCreateFromTemplateModal(<%= template.id %>, '<%= j template.name %>')" 
                        class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-primary hover:bg-primary-dark">
                  <svg class="mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                  </svg>
                  Create Pipeline
                </button>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% else %>
    <div class="text-center py-12 bg-white rounded-lg shadow-sm">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900">No templates</h3>
      <p class="mt-1 text-sm text-gray-500">
        Get started by saving an existing pipeline as a template.
      </p>
      <div class="mt-6">
        <%= link_to pipelines_path, class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-primary hover:bg-primary-dark" do %>
          View Pipelines
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<!-- Create from Template Modal -->
<div id="create-from-template-modal" class="fixed z-10 inset-0 overflow-y-auto hidden">
  <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
    <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity"></div>
    <div class="inline-block align-bottom bg-white rounded-lg px-4 pt-5 pb-4 text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full sm:p-6">
      <%= form_with url: create_from_template_pipelines_path, method: :post do |f| %>
        <input type="hidden" name="template_id" id="template_id_input">
        <div>
          <div class="mt-3 text-center sm:mt-5">
            <h3 class="text-lg leading-6 font-medium text-gray-900">
              Create Pipeline from Template
            </h3>
            <div class="mt-2">
              <p class="text-sm text-gray-500" id="template-name-display"></p>
            </div>
          </div>
        </div>
        <div class="mt-5">
          <label for="pipeline_name" class="block text-sm font-medium text-gray-700">Pipeline Name</label>
          <%= f.text_field :pipeline_name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary focus:ring-primary sm:text-sm", required: true, placeholder: "My New Pipeline" %>
        </div>
        <div class="mt-4">
          <label for="schedule" class="block text-sm font-medium text-gray-700">Schedule (optional)</label>
          <%= f.text_field :schedule, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary focus:ring-primary sm:text-sm font-mono", placeholder: "0 2 * * * (daily at 2 AM)" %>
          <p class="mt-1 text-xs text-gray-500">Leave blank for manual runs only</p>
        </div>
        <div class="mt-5 sm:mt-6 sm:grid sm:grid-cols-2 sm:gap-3 sm:grid-flow-row-dense">
          <%= f.submit "Create Pipeline", class: "w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-primary text-base font-medium text-white hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary sm:col-start-2 sm:text-sm" %>
          <button type="button" onclick="hideCreateFromTemplateModal()" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary sm:mt-0 sm:col-start-1 sm:text-sm">
            Cancel
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
function showCreateFromTemplateModal(templateId, templateName) {
  document.getElementById('template_id_input').value = templateId;
  document.getElementById('template-name-display').textContent = 'Creating from: ' + templateName;
  document.getElementById('create-from-template-modal').classList.remove('hidden');
}

function hideCreateFromTemplateModal() {
  document.getElementById('create-from-template-modal').classList.add('hidden');
}
</script>
