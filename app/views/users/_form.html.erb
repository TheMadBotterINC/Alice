<%= form_with(model: user, class: "space-y-6") do |form| %>
  <% if user.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(user.errors.count, "error") %> prohibited this user from being saved:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="bg-white shadow-sm rounded-lg p-6 space-y-6">
    <!-- Name Field -->
    <div>
      <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :name, 
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary focus:ring-primary sm:text-sm",
          placeholder: "John Doe",
          required: true %>
      <p class="mt-1 text-sm text-gray-500">Full name of the user</p>
    </div>

    <!-- Email Field -->
    <div>
      <%= form.label :email, class: "block text-sm font-medium text-gray-700" %>
      <%= form.email_field :email, 
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary focus:ring-primary sm:text-sm",
          placeholder: "john@example.com",
          required: true %>
      <p class="mt-1 text-sm text-gray-500">Email address for login</p>
    </div>

    <!-- Role Field -->
    <div>
      <%= form.label :role, class: "block text-sm font-medium text-gray-700" %>
      <%= form.select :role, 
          User.roles.keys.map { |role| [role.humanize, role] },
          {},
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary focus:ring-primary sm:text-sm" %>
      <p class="mt-1 text-sm text-gray-500">Role determines user permissions</p>
      
      <!-- Role descriptions -->
      <div class="mt-3 bg-gray-50 rounded-md p-4 text-sm text-gray-600 space-y-2">
        <div class="flex items-start">
          <div class="font-medium text-purple-700 w-24">Admin:</div>
          <div>Full access to all features including creating/editing connectors, pipelines, datasets, and managing users</div>
        </div>
        <div class="flex items-start">
          <div class="font-medium text-gray-700 w-24">Viewer:</div>
          <div>Can view all data, pipeline results, and dashboards but cannot create or modify anything</div>
        </div>
      </div>
    </div>

    <!-- Password Section -->
    <div class="border-t border-gray-200 pt-6">
      <h3 class="text-lg font-medium text-gray-900 mb-4">
        <%= user.new_record? ? "Password" : "Change Password" %>
      </h3>
      
      <% if user.new_record? %>
        <div class="bg-blue-50 border border-blue-200 rounded-md p-4 mb-4">
          <p class="text-sm text-blue-700">
            Leave password fields blank to automatically generate a secure temporary password.
            You'll be shown the password after creating the user.
          </p>
        </div>
      <% else %>
        <div class="bg-blue-50 border border-blue-200 rounded-md p-4 mb-4">
          <p class="text-sm text-blue-700">
            Leave password fields blank to keep the current password unchanged.
          </p>
        </div>
      <% end %>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        <!-- Password Field -->
        <div>
          <%= form.label :password, class: "block text-sm font-medium text-gray-700" %>
          <%= form.password_field :password, 
              class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary focus:ring-primary sm:text-sm",
              placeholder: user.new_record? ? "Leave blank for auto-generated" : "Leave blank to keep current",
              autocomplete: "new-password" %>
          <% if user.new_record? %>
            <p class="mt-1 text-sm text-gray-500">Minimum 8 characters (optional)</p>
          <% else %>
            <p class="mt-1 text-sm text-gray-500">Minimum 8 characters (leave blank to keep current)</p>
          <% end %>
        </div>

        <!-- Password Confirmation Field -->
        <div>
          <%= form.label :password_confirmation, "Confirm Password", class: "block text-sm font-medium text-gray-700" %>
          <%= form.password_field :password_confirmation, 
              class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary focus:ring-primary sm:text-sm",
              placeholder: user.new_record? ? "Leave blank for auto-generated" : "Leave blank to keep current",
              autocomplete: "new-password" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Form Actions -->
  <div class="flex items-center justify-end space-x-3">
    <%= link_to "Cancel", users_path, 
        class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-colors" %>
    <%= form.submit user.new_record? ? "Create User" : "Update User",
        class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-primary hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-colors cursor-pointer" %>
  </div>
<% end %>
